{
  "rules": {
    ".read": false,
    ".write": false,
    "chats": {
      "$chatId": {
        ".read": "auth != null && data.child('members').child(auth.uid).val() === true",
        ".write": "auth != null && ((!data.exists() && newData.child('members').child(auth.uid).val() === true) || data.child('members').child(auth.uid).val() === true)",
        "members": {
          "$uid": {
            ".read": "auth != null && data.parent().child('members').child(auth.uid).val() === true",
            ".write": "auth != null && data.parent().child('members').child(auth.uid).val() === true"
          }
        },
        "messages": {
          "$msgId": {
            // Only members can write to messages in this chat
            ".write": "auth != null && data.parent().parent().child('members').child(auth.uid).val() === true",
            // Validate structure for new messages
            ".validate": "newData.hasChildren(['senderId', 'content', 'type', 'timestamp']) || data.exists()",
            
            "reactions": {
              "$uid": {
                // Only the specific user can add/remove their own reaction
                ".write": "auth.uid === $uid"
              }
            },
            "readBy": {
              "$uid": {
                // Only the specific user can mark as read for themselves
                ".write": "auth.uid === $uid"
              }
            },
            "senderId": {
              ".write": "!data.exists()"
            },
            "content": {
              // Only sender can delete/edit the message content
              ".write": "data.parent().child('senderId').val() === auth.uid || !newData.exists()"
            }
          }
        },
        "typing": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid && root.child('chats').child($chatId).child('members').child(auth.uid).val() === true"
          }
        }
      }
    },
    "portals": {
      "$portalId": {
        ".read": "auth != null",
        "presence": {
          "$uid": {
            ".write": "auth.uid === $uid"
          }
        },
        "messages": {
          "$msgId": {
            ".write": "auth != null && (!data.exists() || data.child('senderId').val() === auth.uid)"
          }
        }
      }
    },
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}

