{
  "rules": {
    ".read": false,
    ".write": false,
    "chats": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "messages": {
          "$msgId": {
            ".validate": "newData.hasChildren(['senderId', 'content', 'type', 'timestamp'])"
          }
        },
        "typing": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    }
  }
}
